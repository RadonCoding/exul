fn __strcmp_ansi_ansi__(a, b) {
    i = 0
    loop {
        if *byte(a + i) == '\0' {
            break
        }
        ca = *byte(a + i)
        cb = *byte(b + i)
        if ca != cb {
            return 0
        }
        i += 1
    }
    return *byte(b + i) == '\0'
}

fn main() {
    result = __strcmp_ansi_ansi__("hello", "hello")
    return result
}